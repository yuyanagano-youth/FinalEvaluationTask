@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}
<div class="d-flex align-items-center gap-3 mb-3 mt-3">


    <a asp-page="./Index" asp-route-Filter="全表示" class="btn btn-secondary text-nowrap">
        全表示
    </a>
    <a asp-page="./Index" asp-route-Filter="未着手" class="btn btn-secondary text-nowrap">
        未着手
    </a>
    <a asp-page="./Index" asp-route-Filter="進行中" class="btn btn-secondary text-nowrap">
        進行中
    </a>
    <a asp-page="./Index" asp-route-Filter="完了" class="btn btn-secondary text-nowrap">
        完了
    </a>

    <form method="post" class="w-25 ms-auto">
    <div class="input-group">
    <input type="text" class="form-control" name = "assignee" placeholder="担当者名を入力">
    <button class="btn btn-outline-success" type="submit" id="button-addon2"><i class="fas fa-search"></i> 検索</button>
    </div>
    </form>
</div>

<div class="text-center container">

    <table class="table table-bordered mx-auto">
        <thead>
            <tr>
                <th>タスク名</th>
                <th>担当者</th>
                <th>期限</th>
                <th>状態</th>
                <th>作成日</th>
                <th>更新日</th>
                <th></th>
            </tr>

        </thead>

        <tbody>
            @foreach (var task in Model.Tasks)
            {
                <tr>
                    <th>@task.TASK_NAME</th>
                    <td>@task.ASSIGNEE</td>
                    <td>@task.DUE_DATE?.ToString("yyyy-MM-dd")</td>
                    <td>@task.STATUS</td>
                    <td>@task.CREATE_DATETIME</td>
                    <td>@task.UPDATE_DATETIME</td>
                    <td>
                        <a asp-page="./Edit" asp-route-id="@task.TASK_ID" class="btn btn-secondary text-nowrap">
                        編集
                        </a>
                    </td>
                </tr>                        
            }
        </tbody>
    </table>

</div>
